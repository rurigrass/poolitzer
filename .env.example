# Copy to .env.local and fill with values from Supabase:
# Project Settings → API (https://supabase.com/dashboard/project/_/settings/api)
#
# The app reads NEXT_PUBLIC_SUPABASE_ANON_KEY (use the anon or publishable public key — not service_role).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-public-key
